# ─── Database ────────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# ─── Backend Public URL (Load Balanced) ──────────────────────────────────────
APP_BASE_URL=http://localhost

# ─── Frontend URL (CORS + Redirects) ────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── JWT & Encryption ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_256_bits
ENCRYPTION_SECRET=your_32_char_encryption_key_here

# ─── Email (Gmail SMTP) ─────────────────────────────────────────────────────
# Use a Gmail App Password, NOT your real password
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=noreply.shunyalink@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ─── AI APIs ────────────────────────────────────────────────────────────────
# Used for auto-categorization, profile roasts, and phishing detection
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# ─── Cloud Storage (Profile Pictures) ───────────────────────────────────────
# Get from: https://cloudinary.com/console → Dashboard → Environment variable
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Google OAuth (Optional — has default) ──────────────────────────────────
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
